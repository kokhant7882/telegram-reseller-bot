# ============================================================
# Telegram Reseller Bot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ------------------------------------------------------------
# BOT CONFIGURATION
# ------------------------------------------------------------

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=1234567890:ABCDEFghijklmnopqrstuvwxyz

# Comma-separated Telegram user IDs for super admins
ADMIN_IDS=123456789,987654321

# Webhook URL (your Vercel deployment URL + /api/webhook)
WEBHOOK_URL=https://your-project.vercel.app/api/webhook

# Secret token for webhook security (random 32+ char string)
WEBHOOK_SECRET=your_super_secret_webhook_token_here

# Bot environment: development | production
NODE_ENV=development

# ------------------------------------------------------------
# DATABASE — NEON (Serverless PostgreSQL)
# ------------------------------------------------------------
# Get your connection string from: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require

DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/resellerbot?sslmode=require

# ------------------------------------------------------------
# CACHE & SESSIONS — UPSTASH REDIS
# ------------------------------------------------------------
# Get from: https://console.upstash.com

UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ------------------------------------------------------------
# PAYMENT GATEWAYS
# ------------------------------------------------------------

# --- KBZPay ---
KBZPAY_ACCOUNT_NUMBER=09xxxxxxxxx
KBZPAY_ACCOUNT_NAME=Your Name
KBZPAY_ENABLED=true

# --- WavePay ---
WAVEPAY_ACCOUNT_NUMBER=09xxxxxxxxx
WAVEPAY_ACCOUNT_NAME=Your Name
WAVEPAY_ENABLED=true

# --- AYA Pay ---
AYAPAY_ACCOUNT_NUMBER=09xxxxxxxxx
AYAPAY_ACCOUNT_NAME=Your Name
AYAPAY_ENABLED=true

# --- Binance Pay ---
# Get from: https://www.binance.com/en/my/payment/merchant
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_MERCHANT_ID=your_merchant_id
BINANCE_ENABLED=true

# --- TRC20 USDT ---
# USDT TRC20 wallet address to receive payments
TRC20_WALLET_ADDRESS=TYour_TRON_Wallet_Address_Here
# TronGrid API key for transaction monitoring
TRONGRID_API_KEY=your_trongrid_api_key
TRC20_ENABLED=true

# USDT to MMK exchange rate (manual setting or fetched from API)
USDT_MMK_RATE=3500

# ------------------------------------------------------------
# FILE STORAGE — CLOUDINARY
# ------------------------------------------------------------
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ENABLED=true

# ------------------------------------------------------------
# CRON SECURITY
# ------------------------------------------------------------
# Secret token to protect cron endpoints (set same in Vercel)
CRON_SECRET=your_cron_secret_token_here

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ------------------------------------------------------------
# BOT SETTINGS (can also be configured via Admin Panel)
# ------------------------------------------------------------

# Minimum deposit amount in MMK
MIN_DEPOSIT_AMOUNT=1000

# Maximum deposit amount in MMK
MAX_DEPOSIT_AMOUNT=10000000

# Referral reward amount in MMK
REFERRAL_REWARD_AMOUNT=500

# Default language (my | en)
DEFAULT_LANGUAGE=my

# Support chat/channel username or ID
SUPPORT_CHANNEL=@your_support_channel

# Rate limit: max requests per minute per user
RATE_LIMIT_PER_MINUTE=30
