{
  "version": 2,
  "buildCommand": "echo 'Serverless bot - no frontend build'",
  "outputDirectory": ".",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
