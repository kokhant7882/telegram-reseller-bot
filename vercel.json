{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "api/cron/cleanup.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
