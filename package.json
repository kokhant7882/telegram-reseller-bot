{
  "name": "telegram-reseller-bot",
  "version": "1.0.0",
  "description": "Professional Telegram Reseller Bot built with TypeScript, grammY, Neon PostgreSQL, and Vercel",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/dev.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluent/bundle": "^0.18.0",
    "@grammyjs/conversations": "^2.0.0",
    "@grammyjs/hydrate": "^1.4.1",
    "@grammyjs/i18n": "^1.0.2",
    "@grammyjs/menu": "^1.3.0",
    "@grammyjs/parse-mode": "^1.10.0",
    "@grammyjs/storage-redis": "^2.4.2",
    "@neondatabase/serverless": "^0.10.4",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.9",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.1",
    "grammy": "^1.27.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.3.0",
    "tslib": "^2.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vercel/node": "^5.8.24",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
